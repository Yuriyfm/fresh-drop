POSTGRES_DB=fresh_drop
POSTGRES_USER=fresh_drop
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://fresh_drop:change-me@db:5432/fresh_drop

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_MARKETS=US,GB,DE,FR,ES,IT,BR,MX,JP,KR,TR,IN,CA,AU,NL,SE,PL,AR,CO,ID,PH,ZA
SPOTIFY_INITIAL_RPS=1
SPOTIFY_MAX_RPS=2
SPOTIFY_MIN_RPS=0.1
SPOTIFY_MAX_CONCURRENCY=1
SPOTIFY_RATE_INCREASE_STEP=0.2
SPOTIFY_RATE_DECREASE_FACTOR=0.5
SPOTIFY_RATE_STABLE_WINDOW_MS=300000
SPOTIFY_RETRY_JITTER_MS=500
SPOTIFY_SEARCH_LIMIT=10
SPOTIFY_MAX_SAFE_OFFSET=1000
SPOTIFY_SPLIT_TOTAL_THRESHOLD=800
SPOTIFY_ARTIST_CACHE_TTL_DAYS=30

CRAWLER_CRON_SCHEDULE=*/15 * * * *
CLEANUP_CRON_SCHEDULE=30 3 * * *

SPOTIFY_CRAWLER_BATCH_SIZE=5
SPOTIFY_CRAWLER_ARTIST_ALBUMS_LIMIT=10
SPOTIFY_CRAWLER_ENABLE_ARTIST_EXPANSION=false
SPOTIFY_CRAWLER_SEARCH_TASK_COOLDOWN_MINUTES=360
# Leave empty to use default shards: tag:new plus a-z/0-9 and aa-99 year:<current-year>.
SPOTIFY_CRAWLER_SEARCH_QUERIES=
RELEASE_RETENTION_DAYS=30

# Use :80 for plain HTTP by server IP, or a real domain for automatic HTTPS.
FRESH_DROP_SITE_ADDRESS=:80
