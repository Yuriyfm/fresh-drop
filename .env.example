# PostgreSQL connection string used by API, sync job, and schema application.
DATABASE_URL=postgres://fresh_drop:fresh_drop@localhost:5432/fresh_drop

# Spotify Web API credentials for release sync.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Spotify market and max number of releases fetched per sync request.
SPOTIFY_MARKET=US
SPOTIFY_SYNC_LIMIT=50
SPOTIFY_SYNC_PAGES=1
