# PostgreSQL connection string used by API, sync job, and schema application.
DATABASE_URL=postgres://fresh_drop:fresh_drop@localhost:5432/fresh_drop

# Spotify Web API credentials for release sync.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Spotify market and max number of releases fetched per sync request.
SPOTIFY_MARKET=US
SPOTIFY_SYNC_LIMIT=50
SPOTIFY_SYNC_PAGES=1
SPOTIFY_API_MIN_REQUEST_INTERVAL_MS=10000

# Search crawler pacing and batch settings.
SPOTIFY_CRAWLER_BATCH_SIZE=5
SPOTIFY_CRAWLER_SEARCH_LIMIT=50
SPOTIFY_CRAWLER_ARTIST_ALBUMS_LIMIT=10
SPOTIFY_CRAWLER_ENABLE_ARTIST_EXPANSION=false
SPOTIFY_CRAWLER_SEARCH_TASK_COOLDOWN_MINUTES=360

# MusicBrainz artist enrichment settings.
MUSICBRAINZ_ENABLED=true
MUSICBRAINZ_BASE_URL=https://musicbrainz.org/ws/2
MUSICBRAINZ_USER_AGENT=FreshDrop/0.1.0 (your-email@example.com)
MUSICBRAINZ_RATE_LIMIT_MS=1100
MUSICBRAINZ_URL_LOOKUP_BATCH_SIZE=100
